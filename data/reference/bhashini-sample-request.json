      "pipelineRequestConfig": {"pipelineId": "<BHASHINI_PIPELINE_ID>"}
    }
  },
  "step2_pipelineConfigResponse_shape": {
    "pipelineInferenceAPIEndPoint": {
      "callbackUrl": "https://dhruva-api.bhashini.gov.in/services/inference/pipeline",
      "inferenceApiKey": {"name": "Authorization", "value": "<issued-at-runtime>"}
    },
    "pipelineResponseConfig": [
      {"taskType": "asr", "config": [{"serviceId": "<asr-service-id-hi>", "language": {"sourceLanguage": "hi"}}]},
      {"taskType": "tts", "config": [{"serviceId": "<tts-service-id-hi>", "language": {"sourceLanguage": "hi"}}]}
    ]
  },
  "step3_asrComputeRequest": {
    "url": "<callbackUrl from step 2>",
    "method": "POST",
