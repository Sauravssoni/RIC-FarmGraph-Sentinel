# FarmGraph Rakshak — environment template (copy to .env; never commit real values)
# The standalone web demo requires no secrets. Connected mode uses the settings below.

# Web: public base URL of the connected demo API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Web: repository base path for GitHub Pages project-site deployments
NEXT_PUBLIC_BASE_PATH=

# API: SQLite demo store location (single-node, demo-grade)
FGR_DB_PATH=./data/runtime/fgr.db

# API: set to "memory" to disable SQLite persistence entirely
FGR_PERSIST=

# API: demo write rate limit (mutating requests per minute per client IP)
FGR_RATE_LIMIT=90

# API: exact comma-separated frontend origins allowed to call the connected API.
# Do not use '*'. Example:
# FGR_ALLOWED_ORIGINS=https://farmgraph-rakshak-web.onrender.com,https://ric-farm-graph-sentinel-web.vercel.app
FGR_ALLOWED_ORIGINS=

# scripts/fetch_public_data.py: free data.gov.in key enables live AGMARKNET refresh
DATAGOVIN_API_KEY=

# --- Government integration adapters (API host only — never in the static frontend) ---
# Bhashini (ULCA) Hindi PoC — see docs/integrations/bhashini.md
BHASHINI_ENABLED=
BHASHINI_USER_ID=
BHASHINI_API_KEY=
BHASHINI_PIPELINE_ID=
BHASHINI_CONFIG_URL=
BHASHINI_TIMEOUT_SEC=12
BHASHINI_CONFIG_CACHE_SEC=300

# IMD weather — see docs/integrations/imd.md (current verified state: IP whitelist required)
IMD_ENABLED=
IMD_API_URL=
IMD_PROBE_TTL_SEC=21600
IMD_DATAGOV_RESOURCE_ID=

# data.gov.in shared key (IMD OGD products + AGMARKNET mandi prices)
DATAGOV_API_KEY=
AGMARKNET_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070
AGMARKNET_TIMEOUT_SEC=15
