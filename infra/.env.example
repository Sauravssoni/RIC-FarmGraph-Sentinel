# FarmGraph Rakshak — environment template (copy to .env; never commit real values)
# Everything is optional: the web app runs fully offline from its bundled demo seed.

# Web: base URL of the optional demo API (enables API provider badge + real sync writes)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Web: base path for GitHub Pages project-site deploys (set by the pages workflow)
NEXT_PUBLIC_BASE_PATH=

# API: SQLite demo store location (single-node, demo-grade)
FGR_DB_PATH=./data/runtime/fgr.db

# API: set to "memory" to disable SQLite persistence entirely
FGR_PERSIST=

# API: demo write rate limit (mutating requests per minute per client IP)
FGR_RATE_LIMIT=90

# scripts/fetch_public_data.py: free data.gov.in key enables the live AGMARKNET fetch
DATAGOVIN_API_KEY=
